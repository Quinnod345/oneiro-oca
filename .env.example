# Anthropic Claude API key (required for hypothesis/thinking layers)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI API key (required for embeddings + semantic retrieval)
OPENAI_API_KEY=your_openai_key_here

# PostgreSQL connection string
# Defaults to postgres://localhost/oneiro if omitted by scripts
DATABASE_URL=postgres://localhost/oneiro
