# Anthropic Claude auth mode:
# - auto  = prefer API key if present, fall back to Claude OAuth CLI
# - api   = use ANTHROPIC_API_KEY directly
# - oauth = use local Claude CLI OAuth session only
ANTHROPIC_AUTH_MODE=auto

# Anthropic Claude API key (used when ANTHROPIC_AUTH_MODE=auto|api)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Vision provider:
# - auto      = prefer Anthropic vision when API mode is available, otherwise OpenAI
# - anthropic = use Anthropic vision API
# - openai    = use OpenAI vision
OCA_VISION_PROVIDER=auto

# OpenAI API key (required for embeddings + semantic retrieval)
OPENAI_API_KEY=your_openai_key_here

# PostgreSQL connection string
# Defaults to postgres://localhost/oneiro if omitted by scripts
DATABASE_URL=postgres://localhost/oneiro
